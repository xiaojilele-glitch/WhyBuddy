# ============================================================
# Cube Pets Office Environment Configuration
# Copy this file to .env and fill in your values
# ============================================================

# MySQL / Session / Redis configuration for ToC auth and project isolation
DATABASE_PROVIDER=mysql
DB_HOST=localhost
DB_PORT=3306
DB_NAME=cube_pets_office
DB_USER=root
DB_PASSWORD=your_password_here

PORT=3001
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173

SESSION_SECRET=replace_with_a_64_char_random_hex_secret

# Solo Trae sandbox only: bypass HTTP auth and admin checks for sandbox runs.
SOLO_TRAE_BYPASS_AUTH=false
# Skill bridge uses the local server inside the Trae sandbox.
SKILL_BRIDGE_BASE_URL=http://localhost:3001
# Skill session facade exposes start/respond/snapshot/agent-stream inside the Trae sandbox.
SKILL_SESSION_BASE_PATH=/api/skill/session
SESSION_COOKIE_NAME=cube_office_session
SESSION_TTL_DAYS=30
EMAIL_CODE_TTL_SECONDS=600
EMAIL_CODE_PEPPER=replace_with_a_random_email_code_pepper
EMAIL_DELIVERY_MODE=console
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_smtp_user
SMTP_PASSWORD=your_smtp_password
SMTP_FROM=Cube Pets Office <no-reply@example.com>

REDIS_ENABLED=false
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password_here
REDIS_DB=2
REDIS_KEY_PREFIX=cube:pets:office:

QUEUE_REDIS_ENABLED=false
QUEUE_REDIS_HOST=localhost
QUEUE_REDIS_PORT=6379
QUEUE_REDIS_PASSWORD=your_queue_redis_password_here
QUEUE_REDIS_DB=3
QUEUE_REDIS_KEY_PREFIX=cube:pets:office:queue:

# ── Autopilot Capability Runtime ──────────────────────────────
# 主开关：控制 5 条 `/autopilot` capability bridge（docker / mcp /
# role / aigc-node / stage activation）的默认装配行为。
# Master switch for the five autopilot capability bridges:
#   "true"  → 5 条桥在依赖就位时默认走真实执行（Docker / MCP / LLM）
#             All five bridges default to real execution when their
#             dependencies (Docker daemon / MCP adapter / LLM apiKey)
#             are available; unreachable deps gracefully fall back to
#             simulated output without failing server startup.
#   "false" → 5 条桥统一走模板化 simulated fallback
#             All five bridges run in deterministic template fallback.
#   unset   → 等价于 "false"（保留传统 opt-in 语义）
#             Preserves legacy opt-in semantics (same as "false" today).
# 下方 5 个 `BLUEPRINT_*_CAPABILITY_BRIDGE_ENABLED` / `BLUEPRINT_*_ENABLED`
# 环境变量的显式值始终优先，覆盖本开关；`dev:all` 脚本默认注入 "true"，
# 测试环境（`BUILD_TARGET=test`）始终强制解析为 "false" 保证既有测试兼容。
# Explicit BLUEPRINT_*_ENABLED values below always win over this switch.
# The `dev:all` script auto-injects "true"; `BUILD_TARGET=test` (set by
# vitest setup) hard-locks all five bridges to "false" regardless.
AUTOPILOT_REAL_RUNTIME=true

LLM_API_KEY=your_api_key_here
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-5.4
LLM_WIRE_API=responses
LLM_REASONING_EFFORT=medium
LLM_TIMEOUT_MS=600000
LLM_MAX_CONCURRENT=9999
WORKFLOW_CONTEXT_RECENT_LIMIT=12
WORKFLOW_CONTEXT_EARLIER_PREVIEW_LIMIT=6
WORKFLOW_CONTEXT_ENTRY_CHAR_LIMIT=320
WORKFLOW_CONTEXT_TOTAL_CHAR_LIMIT=6000

FALLBACK_LLM_API_KEY=your_fallback_api_key_here
FALLBACK_LLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4
FALLBACK_LLM_MODEL=glm-5-turbo
FALLBACK_LLM_WIRE_API=chat_completions
FALLBACK_LLM_TIMEOUT_MS=600000
FALLBACK_LLM_FORCE_MODEL=true
FALLBACK_LLM_STREAM=false
FALLBACK_LLM_CHAT_THINKING_TYPE=disabled

# Mission / tasks integration
MISSION_SMOKE_ENABLED=false
MISSION_SMOKE_SERVER_PORT=3101
MISSION_SMOKE_EXECUTOR_PORT=3131
MISSION_SMOKE_FEISHU_PORT=3141
MISSION_RESTART_SMOKE_PORT=3102
EXECUTOR_CALLBACK_SECRET=change_me_executor_secret
EXECUTOR_CALLBACK_MAX_SKEW_SECONDS=300

# Lobster executor
LOBSTER_EXECUTOR_BASE_URL=http://127.0.0.1:3031
LOBSTER_EXECUTOR_HOST=0.0.0.0
LOBSTER_EXECUTOR_PORT=3031
LOBSTER_EXECUTOR_DATA_ROOT=tmp/lobster-executor
LOBSTER_EXECUTOR_NAME=lobster-executor
LOBSTER_EXECUTION_MODE=real
LOBSTER_DEFAULT_IMAGE=node:20-slim
# Strong AI Agent image for aiEnabled Docker jobs. Build with:
# npm run build:agent-image
# Leave unset to keep using the legacy baseline image.
# LOBSTER_AGENT_IMAGE=cube-ai-agent-sandbox:latest
LOBSTER_AI_IMAGE=cube-ai-sandbox:latest
LOBSTER_MAX_CONCURRENT_JOBS=2
# DOCKER_HOST=tcp://127.0.0.1:2375
# DOCKER_TLS_VERIFY=1
# DOCKER_CERT_PATH=/path/to/certs

# ── Autopilot Capability Bridge Flags（通常不需单独设置） ──────────
# 以下 5 个 flag 覆盖 `/autopilot` 5 条 capability bridge 的 tier-1 门禁。
# 通常由上方 AUTOPILOT_REAL_RUNTIME 主开关统一驱动；只有需要单独关闭
# 某一条桥或在测试中显式 opt-in 时才需要单独设置，此时显式值始终最优先。
# The following five bridge-level flags override AUTOPILOT_REAL_RUNTIME
# on a per-bridge basis. Typically left unset and driven by the master
# switch above. Explicit values here always take precedence.
# BLUEPRINT_DOCKER_CAPABILITY_BRIDGE_ENABLED=true
# BLUEPRINT_MCP_CAPABILITY_BRIDGE_ENABLED=true
# BLUEPRINT_ROLE_CAPABILITY_BRIDGE_ENABLED=true
# BLUEPRINT_AIGC_NODE_CAPABILITY_BRIDGE_ENABLED=true
# BLUEPRINT_AGENT_CREW_STAGE_ACTIVATION_ENABLED=true

# ── Autopilot Agent-Driven Pipeline ───────────────────────────
# Agent 驱动管线：Planner 角色通过 ReAct Agent Loop 自主生成 RouteSet。
# Agent-driven pipeline: Planner role autonomously generates RouteSet
# via ReAct Agent Loop (clone → analyze → generate routes).
# Default "false" — existing buildRouteSet / routeSetLlmGenerator path
# remains active. Set to "true" to enable the agent-driven path.
BLUEPRINT_AGENT_DRIVEN_PIPELINE_ENABLED=false

# ── Autopilot Agent Reasoning Stream ──────────────────────────
# autopilot-agent-reasoning-stream spec Task 7：Agent 推理流前端流式可视化总开关。
# 仅当显式设为 "true" 时才会订阅 CallbackReceiver.onProgress 并把 role.agent.* 事件
# 推送到前端 BlueprintRealtimeStore。BUILD_TARGET=test 下视为 false，保留既有 5140+
# 测试默认兼容性。
BLUEPRINT_AGENT_REASONING_STREAM_ENABLED=false

# ── Autopilot Role Container Loader ────────────────────────────
# 角色容器 loader：每个 active 角色在 stage 激活时获得一个 Docker 容器
# （或 lite-mode 进程沙箱），并绑定其声明的 MCP / Skill / AIGC 节点。
# Runtime loader for per-role composite agents: each active role receives
# a Docker container (or lite-mode process sandbox) with its declared
# MCPs / Skills / AIGC nodes bound. Driven by AUTOPILOT_REAL_RUNTIME
# unless explicitly set. "test" BUILD_TARGET always forces "false".
BLUEPRINT_ROLE_CONTAINER_LOADER_ENABLED=true
# 强制指定容器模式（调试用）。留空时按 executor 可达性自动 real→lite 降级。
# Force a specific container mode for testing / debugging. Leave unset
# for automatic real→lite fallback when executor is unreachable.
# BLUEPRINT_ROLE_CONTAINER_LOADER_MODE_OVERRIDE=real|lite
BLUEPRINT_ROLE_CONTAINER_PROVISION_TIMEOUT_MS=30000

# ── Lobster Executor Security Sandbox ─────────────────────────────
# Security level preset: "strict" (default), "balanced", or "permissive"
LOBSTER_SECURITY_LEVEL=strict
# Container user UID (default: 65534 = nobody)
LOBSTER_CONTAINER_USER=65534
# Max memory per container (e.g. 512m, 1g)
LOBSTER_MAX_MEMORY=512m
# Max CPU cores per container (e.g. 1.0, 2.0)
LOBSTER_MAX_CPUS=1.0
# Max processes inside the container
LOBSTER_MAX_PIDS=256
# tmpfs /tmp size for read-only root filesystem mode
LOBSTER_TMPFS_SIZE=64m
# Comma-separated domain/IP whitelist for balanced network mode
LOBSTER_NETWORK_WHITELIST=
# Path to custom seccomp profile JSON (leave empty to use built-in)
# LOBSTER_SECCOMP_PROFILE=

# Feishu mission bridge
FEISHU_ENABLED=true
FEISHU_MODE=mock
FEISHU_BASE_TASK_URL=http://127.0.0.1:3001
FEISHU_PROGRESS_THROTTLE_PERCENT=15
FEISHU_RELAY_SECRET=change_me_feishu_relay_secret
FEISHU_RELAY_MAX_SKEW_SECONDS=300
FEISHU_RELAY_NONCE_TTL_SECONDS=300
FEISHU_WEBHOOK_VERIFICATION_TOKEN=
FEISHU_WEBHOOK_ENCRYPT_KEY=
FEISHU_WEBHOOK_MAX_SKEW_SECONDS=300
FEISHU_WEBHOOK_DEDUP_TTL_SECONDS=600
FEISHU_WEBHOOK_DEDUP_FILE=data/feishu/feishu-webhook-dedup.json
FEISHU_MESSAGE_FORMAT=card-live
FEISHU_FINAL_SUMMARY_MODE=both
FEISHU_DELIVERY_MAX_RETRIES=2
FEISHU_DELIVERY_RETRY_BASE_MS=300
FEISHU_DELIVERY_RETRY_MAX_MS=5000
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_TENANT_ACCESS_TOKEN=
FEISHU_API_BASE_URL=https://open.feishu.cn/open-apis

# ── Vision LLM Configuration ──────────────────────────────────────
# Optional: dedicated Vision LLM for image analysis.
# Fallback chain: VISION_LLM_* → FALLBACK_LLM_* → main LLM_*
# VISION_LLM_API_KEY=
# VISION_LLM_BASE_URL=
# VISION_LLM_MODEL=
# VISION_LLM_WIRE_API=chat_completions
# VISION_LLM_MAX_TOKENS=1000
# VISION_LLM_DETAIL=low
# VISION_LLM_TIMEOUT_MS=30000

# ── Voice (TTS / STT) Configuration ───────────────────────────────
# Optional: server-side TTS and STT services.
# When not configured, the frontend falls back to browser Web Speech APIs.
# TTS_API_URL=https://api.openai.com/v1/audio/speech
# TTS_API_KEY=
# TTS_MODEL=tts-1
# TTS_VOICE=alloy
# STT_API_URL=https://api.openai.com/v1/audio/transcriptions
# STT_API_KEY=
# STT_MODEL=whisper-1

# ── Agent Permission Model ─────────────────────────────────────────
# JWT signing secret for CapabilityToken (leave empty to auto-generate in dev)
PERMISSION_TOKEN_SECRET=
# Default token TTL in milliseconds (default: 7200000 = 2 hours)
PERMISSION_TOKEN_DEFAULT_TTL_MS=7200000
# LRU cache capacity for permission check results
PERMISSION_CACHE_SIZE=10000
# Cache TTL in milliseconds (default: 60000 = 1 minute)
PERMISSION_CACHE_TTL_MS=60000
# Enable permission audit logging
PERMISSION_AUDIT_ENABLED=true

# ── UE5 Local Streaming Runtime ────────────────────────────────
# Required: Path to UE5 editor executable
# UE_EDITOR_PATH=C:/Program Files/Epic Games/UE_5.4/Engine/Binaries/Win64/UnrealEditor.exe
# Required: Path to UE5 project file (.uproject)
# UE_PROJECT_PATH=C:/Projects/MyProject/MyProject.uproject
# Required: Map/level to load on startup
# UE_MAP_NAME=/Game/Maps/MainLevel
# Optional: Render resolution (default: 1920x1080)
# UE_RESOLUTION_WIDTH=1920
# UE_RESOLUTION_HEIGHT=1080
# Optional: Pixel Streaming signaling port (default: 8888)
# UE_PIXEL_STREAMING_PORT=8888
# Optional: Additional UE5 command-line arguments (comma-separated)
# UE_EXTRA_ARGS=-Windowed,-ForceRes
# Optional: Max startup timeout in ms (default: 30000)
# UE_STARTUP_TIMEOUT_MS=30000

# Blueprint LLM per-module invocation timeouts (ms).
# Each module defaults to 30_000 if unset; max cap is 180_000.
# BLUEPRINT_ROUTESET_LLM_TIMEOUT_MS=180000
# BLUEPRINT_CLARIFICATION_LLM_TIMEOUT_MS=180000
# BLUEPRINT_SPEC_DOCUMENTS_LLM_TIMEOUT_MS=180000
# BLUEPRINT_EFFECT_PREVIEW_LLM_TIMEOUT_MS=180000
# BLUEPRINT_PROMPT_PACKAGE_LLM_TIMEOUT_MS=180000
# BLUEPRINT_ENGINEERING_HANDOFF_LLM_TIMEOUT_MS=180000
# BLUEPRINT_ROLE_CAPABILITY_BRIDGE_TIMEOUT_MS=180000
# BLUEPRINT_AIGC_NODE_CAPABILITY_BRIDGE_TIMEOUT_MS=180000

# === Autopilot LLM-driven SPEC generation ===
# autopilot-llm-spec-generation spec：spec_tree / spec_docs 阶段的真实 LLM 推导旗标。
# 默认全部关闭（opt-in），仅在显式置 "true" 且 apiKey 就位时切换到 real 模式。
# `BUILD_TARGET=test` 始终强制视作关闭（下述 LLM 旗标在测试环境一律按 `false` 解析），
# 保证既有 5140+ 测试默认走 template fallback；集成测试需要打开 LLM 推导时，
# 可通过 `vi.stubEnv("BLUEPRINT_SPEC_TREE_LLM_ENABLED", "true")` 或
# `vi.stubEnv("BLUEPRINT_SPEC_DOCS_LLM_ENABLED", "true")` 单独开启对应阶段。
# 启用 spec_tree 阶段的真实 LLM 推导（默认关闭，opt-in）
BLUEPRINT_SPEC_TREE_LLM_ENABLED=false
# 启用 spec_docs 阶段的真实 LLM 生成（默认关闭，opt-in）
BLUEPRINT_SPEC_DOCS_LLM_ENABLED=false
# spec_tree 单次 Agent 循环总超时（默认 180000 ms，含仓库抓取 + 推理预算）
BLUEPRINT_SPEC_TREE_LLM_TIMEOUT_MS=180000
# spec_docs 单节点 LLM 调用超时（默认 180000 ms）
BLUEPRINT_SPEC_DOCS_LLM_TIMEOUT_MS=180000
# spec_tree 阶段仓库上下文最大 token 数（默认 32000，超过则按目录摘要截断）
BLUEPRINT_SPEC_TREE_LLM_MAX_REPO_TOKENS=32000

# === Image generation API (autopilot-image-rendering-and-visual-system Stage C) ===
# autopilot-image-rendering-and-visual-system spec Stage C：effect_preview 阶段
# 真实图像渲染流水线读取的 7 个 IMAGE_GEN_* 环境变量。仅服务端 ImageApiClient
# (server/routes/blueprint/effect-preview/image-api-client.ts) 一处读取；浏览器侧
# 从不直连 IMAGE_GEN_BASE_URL，也不会在响应中收到 IMAGE_GEN_API_KEY。
# 仅服务端读取，绝不返回到客户端响应；缺失触发 key-missing 降级
IMAGE_GEN_API_KEY=
# image proxy 域名，例如 https://image-proxy.example.com
IMAGE_GEN_BASE_URL=
# 枚举内 gpt-image-2 / gemini-2.5-flash-image / gemini-3.1-flash-image-preview / gemini-3-pro-image-preview
IMAGE_GEN_MODEL=gpt-image-2
# 与 /v1/image/created 二选一
IMAGE_GEN_PATH=/v1/images/generations
# 枚举 1K / 2K / 4K / 512
IMAGE_GEN_DEFAULT_SIZE=1K
# 枚举 1:1 / 2:3 / 3:2 / auto
IMAGE_GEN_DEFAULT_ASPECT=1:1
# 整数毫秒，必须 > 0
IMAGE_GEN_TIMEOUT_MS=60000
