{
  "name": "whybuddy",
  "version": "1.0.0",
  "type": "module",
  "license": "MIT",
  "scripts": {
    "dev": "vite --host",
    "dev:frontend": "vite --host",
    "dev:server": "tsx watch --include server/**/* --include shared/**/* --exclude data/**/* --exclude client/**/* --exclude dist/**/* --exclude .git/**/* --exclude .manus-logs/**/* server/index.ts",
    "dev:all": "node scripts/dev-all.mjs",
    "dev:advanced": "node scripts/dev-all.mjs",
    "dev:stop": "node scripts/dev-stop.mjs",
    "lint": "prettier --check \"package.json\" \"README.md\" \".github/workflows/*.yml\" \".kiro/specs/release-stability-guardrails-v2/*.md\" \".kiro/steering/execution-plan.md\"",
    "lint:autopilot-colors": "node scripts/lint-autopilot-colors.mjs",
    "typecheck": "node --run check",
    "build": "vite build && esbuild server/index.ts --platform=node --packages=external --bundle --format=esm --outdir=dist",
    "build:pages": "node scripts/build-pages.mjs",
    "start": "node scripts/start-prod.mjs",
    "preview": "vite preview --host",
    "check": "tsc --noEmit",
    "test": "node --run test:client && node --run test:server && node --run test:executor",
    "test:client": "vitest run client/src",
    "test:server": "node scripts/test-server.mjs",
    "test:executor": "vitest run --config services/lobster-executor/vitest.config.ts",
    "test:decision": "vitest run --config vitest.config.server.ts server/tests/hitl-decision.test.ts server/tests/hitl-decision.property.test.ts",
    "test:socket-reconnect": "vitest run --config vite.config.ts src/lib/tasks-store.socket-reconnect.test.ts",
    "test:guardrails": "node --run test:decision && node --run test:socket-reconnect",
    "smoke:prod": "node scripts/prod-smoke.mjs",
    "smoke:executor": "node scripts/lobster-executor-smoke.mjs",
    "build:agent-image": "node scripts/build-agent-sandbox-image.mjs",
    "smoke:agent-image": "node scripts/agent-sandbox-smoke.mjs",
    "smoke:agent-executor-browser": "node scripts/agent-sandbox-executor-browser-smoke.mjs",
    "smoke:agent-executor-skill": "node scripts/agent-sandbox-executor-skill-smoke.mjs",
    "smoke:mission": "node scripts/mission-integration-smoke.mjs",
    "smoke:restart": "node scripts/mission-restart-smoke.mjs",
    "smoke:whybuddy": "node scripts/whybuddy-browser-smoke.mjs",
    "smoke:whybuddy-store": "node scripts/whybuddy-store-api-smoke.mjs",
    "verify:whybuddy-v5": "pnpm exec vitest run client/src/lib/whybuddy-runtime.test.ts client/src/lib/whybuddy-runtime.fullpath-core.test.ts client/src/lib/whybuddy-runtime.fullpath-status.test.tsx client/src/lib/whybuddy-runtime.fullpath-budget.test.ts client/src/lib/whybuddy-runtime.fullpath-projection.test.ts client/src/lib/whybuddy-runtime.fullpath-invariants.test.ts --reporter=dot && pnpm exec vitest run --config vitest.config.server.ts server/routes/__tests__/whybuddy.execute-capability.test.ts server/routes/__tests__/whybuddy.sessions-store.test.ts --reporter=dot && pnpm exec tsc --noEmit --pretty false && pnpm run smoke:whybuddy",
    "smoke:release": "node --run smoke:prod && node --run smoke:executor && node --run smoke:mission && node --run smoke:restart",
    "test:release": "node --run lint && node --run typecheck && node --run test && node --run build && node --run smoke:release",
    "format": "prettier --write ."
  },
  "dependencies": {
    "@ant-design/graphs": "2.1.1",
    "@antv/g6": "5.1.1",
    "@hookform/resolvers": "^5.2.2",
